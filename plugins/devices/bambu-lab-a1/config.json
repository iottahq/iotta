{
  "credentials": [
    {
      "field": "ip",
      "type": "string",
      "label": "IP Address",
      "placeholder": "192.168.1.42",
      "required": true,
      "example": "192.168.1.42"
    },
    {
      "field": "serial",
      "type": "string",
      "label": "Serial Number",
      "placeholder": "01S00C123456789",
      "required": true,
      "example": "01S00C123456789"
    },
    {
      "field": "access_code",
      "type": "secret",
      "label": "Access Code",
      "placeholder": "12345678",
      "required": true,
      "example": "12345678"
    }
  ],

  "protocols": {
    "mqtt": {
      "host": "{ip}",
      "port": 8883,
      "tls": true,
      "username": "bblp",
      "password": "{access_code}",
      "subscribe_topics": [
        "device/{serial}/report"
      ],
      "on_connect_publish": {
        "topic": "device/{serial}/request",
        "payload": {
          "pushing": {
            "sequence_id": "0",
            "command": "pushall",
            "version": 1,
            "push_target": 1
          }
        }
      }
    },
    "ftp": {
      "host": "{ip}",
      "port": 990,
      "tls": "implicit",
      "username": "bblp",
      "password": "{access_code}"
    }
  },

  "actions": {

    "send": {
      "print": {
        "protocol": "mqtt",
        "label": "Start Print",
        "topic": "device/{serial}/request",
        "payload": {
          "print": {
            "sequence_id": "1",
            "command": "project_file",
            "param": "Metadata/plate_{plate}.gcode",
            "project_id": "0",
            "profile_id": "0",
            "task_id": "0",
            "subtask_id": "0",
            "subtask_name": "{filename}",
            "file": "",
            "url": "file:///{file_path}",
            "md5": "",
            "timelapse": "{timelapse}",
            "bed_type": "auto",
            "bed_leveling": "{bed_leveling}",
            "flow_cali": "{flow_cali}",
            "vibration_cali": "{vibration_cali}",
            "layer_inspect": false,
            "use_ams": true,
            "ams_mapping": ["{ams_slot}"],
            "plate_idx": "{plate_idx}"
          }
        },
        "input": {
          "file_path":      { "type": "string",  "required": true },
          "filename":       { "type": "string",  "required": true },
          "ams_slot":       { "type": "integer", "default": 0 },
          "plate":          { "type": "integer", "default": 1 },
          "plate_idx":      { "type": "integer", "default": 0 },
          "bed_leveling":   { "type": "boolean", "default": true },
          "timelapse":      { "type": "boolean", "default": false },
          "flow_cali":      { "type": "boolean", "default": false },
          "vibration_cali": { "type": "boolean", "default": false }
        },
        "example": {
          "file_path": "/sdcard/3d_printer/cache/benchy.3mf",
          "filename": "benchy.3mf",
          "ams_slot": 0,
          "plate": 1,
          "plate_idx": 0,
          "bed_leveling": true,
          "timelapse": false,
          "flow_cali": false,
          "vibration_cali": false
        }
      },

      "pause": {
        "protocol": "mqtt",
        "label": "Pause Print",
        "topic": "device/{serial}/request",
        "payload": {
          "print": { "sequence_id": "1", "command": "pause" }
        },
        "example": {}
      },

      "resume": {
        "protocol": "mqtt",
        "label": "Resume Print",
        "topic": "device/{serial}/request",
        "payload": {
          "print": { "sequence_id": "1", "command": "resume" }
        },
        "example": {}
      },

      "stop": {
        "protocol": "mqtt",
        "label": "Stop Print",
        "topic": "device/{serial}/request",
        "payload": {
          "print": { "sequence_id": "1", "command": "stop" }
        },
        "example": {}
      },

      "home": {
        "protocol": "mqtt",
        "label": "Home Axes",
        "topic": "device/{serial}/request",
        "payload": {
          "print": { "sequence_id": "1", "command": "gcode_line", "param": "G28 \n" }
        },
        "example": {}
      },

      "clear_error": {
        "protocol": "mqtt",
        "label": "Clear Error",
        "topic": "device/{serial}/request",
        "payload": {
          "print": { "sequence_id": "1", "command": "clean_print_error" }
        },
        "example": {}
      },

      "light": {
        "protocol": "mqtt",
        "label": "Light Control",
        "topic": "device/{serial}/request",
        "payload": {
          "system": {
            "sequence_id": "1",
            "command": "ledctrl",
            "led_node": "work_light",
            "led_mode": "{mode}",
            "led_on_time": 500,
            "led_off_time": 500,
            "loop_times": 0,
            "interval_time": 0
          }
        },
        "input": {
          "mode": { "type": "string", "default": "on", "enum": ["on", "off", "flashing"] }
        },
        "example": {
          "mode": "on"
        }
      },

      "upload_file": {
        "protocol": "ftp",
        "label": "Upload File",
        "method": "upload",
        "input": {
          "path": { "type": "string", "required": true },
          "data": { "type": "bytes",  "required": true }
        },
        "example": {
          "path": "/sdcard/3d_printer/cache/benchy.3mf"
        }
      },

      "delete_file": {
        "protocol": "ftp",
        "label": "Delete File",
        "method": "delete",
        "input": {
          "path": { "type": "string", "required": true }
        },
        "example": {
          "path": "/sdcard/3d_printer/cache/benchy.3mf"
        }
      }
    },

    "request": {
      "snapshot": {
        "protocol": "camera",
        "label": "Snapshot",
        "port": 6000,
        "auth": {
          "username": "bblp",
          "password": "{access_code}"
        },
        "example": {}
      },

      "files": {
        "protocol": "ftp",
        "label": "List Files",
        "method": "list",
        "input": {
          "path": { "type": "string"}
        },
        "example": {
          "path": "/"
        }
      }
    },

    "stream": {
      "status": {
        "protocol": "mqtt",
        "label": "Live Status",
        "topic": "device/{serial}/report",
        "filter": {
          "key": "print.command",
          "value": "push_status"
        },
        "merge": true,
        "emit_as": "websocket"
      },

      "camera": {
        "protocol": "camera",
        "label": "Camera Feed",
        "port": 6000,
        "auth": {
          "username": "bblp",
          "password": "{access_code}"
        },
        "emit_as": "websocket"
      }
    }

  }
}