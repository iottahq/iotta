{
    "send": {
        "print": {
            "protocol": "mqtt",
            "label": "Start Print",
            "method": "publish",
            "topic": "device/{serial}/request",
            "payload": {
                "print": {
                    "sequence_id": "1",
                    "command": "project_file",
                    "param": "Metadata/plate_{plate}.gcode",
                    "project_id": "0",
                    "profile_id": "0",
                    "task_id": "0",
                    "subtask_id": "0",
                    "subtask_name": "{filename}",
                    "file": "",
                    "url": "file:///{file_path}",
                    "md5": "",
                    "timelapse": "{timelapse}",
                    "bed_type": "auto",
                    "bed_leveling": "{bed_leveling}",
                    "flow_cali": "{flow_cali}",
                    "vibration_cali": "{vibration_cali}",
                    "layer_inspect": false,
                    "use_ams": true,
                    "ams_mapping": [
                        "{ams_slot}"
                    ],
                    "plate_idx": "{plate_idx}"
                }
            },
            "input": {
                "file_path": {
                    "type": "string",
                    "required": true
                },
                "filename": {
                    "type": "string",
                    "required": true
                },
                "ams_slot": {
                    "type": "integer",
                    "required": true,
                    "default": "0"
                },
                "plate": {
                    "type": "integer",
                    "required": true,
                    "default": "1"
                },
                "plate_idx": {
                    "type": "integer",
                    "required": true,
                    "default": "0"
                },
                "bed_leveling": {
                    "type": "boolean",
                    "required": true,
                    "default": "true"
                },
                "timelapse": {
                    "type": "boolean",
                    "required": true,
                    "default": "false"
                },
                "flow_cali": {
                    "type": "boolean",
                    "required": true,
                    "default": "false"
                },
                "vibration_cali": {
                    "type": "boolean",
                    "required": true,
                    "default": "false"
                }
            },
            "example": {
                "file_path": "/sdcard/3d_printer/cache/benchy.3mf",
                "filename": "benchy.3mf",
                "ams_slot": 0,
                "plate": 1,
                "plate_idx": 0,
                "bed_leveling": true,
                "timelapse": false,
                "flow_cali": false,
                "vibration_cali": false
            }
        },
        "pause": {
            "protocol": "mqtt",
            "label": "Pause Print",
            "method": "publish",
            "topic": "device/{serial}/request",
            "payload": {
                "print": {
                    "sequence_id": "1",
                    "command": "pause"
                }
            }
        },
        "resume": {
            "protocol": "mqtt",
            "label": "Resume Print",
            "method": "publish",
            "topic": "device/{serial}/request",
            "payload": {
                "print": {
                    "sequence_id": "1",
                    "command": "resume"
                }
            }
        },
        "stop": {
            "protocol": "mqtt",
            "label": "Stop Print",
            "method": "publish",
            "topic": "device/{serial}/request",
            "payload": {
                "print": {
                    "sequence_id": "1",
                    "command": "stop"
                }
            }
        },
        "home": {
            "protocol": "mqtt",
            "label": "Home Axes",
            "method": "publish",
            "topic": "device/{serial}/request",
            "payload": {
                "print": {
                    "sequence_id": "1",
                    "command": "gcode_line",
                    "param": "G28 \n"
                }
            }
        },
        "clear_error": {
            "protocol": "mqtt",
            "label": "Clear Error",
            "method": "publish",
            "topic": "device/{serial}/request",
            "payload": {
                "print": {
                    "sequence_id": "1",
                    "command": "clean_print_error"
                }
            }
        },
        "light": {
            "protocol": "mqtt",
            "label": "Light Control",
            "method": "publish",
            "topic": "device/{serial}/request",
            "payload": {
                "system": {
                    "sequence_id": "1",
                    "command": "ledctrl",
                    "led_node": "work_light",
                    "led_mode": "{mode}",
                    "led_on_time": 500,
                    "led_off_time": 500,
                    "loop_times": 0,
                    "interval_time": 0
                }
            },
            "input": {
                "mode": {
                    "type": "string",
                    "required": true,
                    "default": "on"
                }
            },
            "example": {
                "mode": "on"
            }
        },
        "upload_file": {
            "protocol": "ftp",
            "label": "Upload File",
            "method": "upload",
            "payload": {},
            "input": {
                "path": {
                    "type": "string",
                    "required": true
                },
                "data": {
                    "type": "bytes",
                    "required": true
                }
            },
            "example": {
                "path": "/sdcard/3d_printer/cache/benchy.3mf"
            }
        },
        "delete_file": {
            "protocol": "ftp",
            "label": "Delete File",
            "method": "delete",
            "payload": {},
            "input": {
                "path": {
                    "type": "string",
                    "required": true
                }
            },
            "example": {
                "path": "/sdcard/3d_printer/cache/benchy.3mf"
            }
        }
    },
    "request": {
        "snapshot": {
            "protocol": "camera",
            "label": "Snapshot",
            "input": {
                "path": {
                    "type": "string",
                    "default": "/"
                }
            }
        },
        "files": {
            "protocol": "ftp",
            "label": "List Files",
            "method": "list",
            "input": {
                "path": {
                    "type": "string",
                    "default": "/"
                }
            }
        }
    },
    "stream": {
        "status": {
            "protocol": "mqtt",
            "label": "Live Status",
            "method": "subscribe",
            "topic": "device/{serial}/report",
            "filter": {
                "key": "print.command",
                "value": "push_status"
            },
            "merge": true,
            "emit_as": "websocket"
        },
        "camera": {
            "protocol": "camera",
            "label": "Camera Feed",
            "merge": true,
            "emit_as": "websocket"
        }
    }
}